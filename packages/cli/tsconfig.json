{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "../../apps/**/*",
    "../../packages/sdk/**/*",
    "../../packages/ai/**/*",
    "../../packages/runtime/**/*",
    "../../packages/ui/**/*",
    "../../packages/local-dev/**/*"
  ]
}
