{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreBinaries": ["playwright"],
  "workspaces": {
    ".": {
      "entry": ["plugins/**/*"],
      "project": [],
      "ignoreDependencies": []
    },
    "packages/ui": {
      // Tailwind v4 @source directives in CSS are not JS imports; knip reports them as unresolved
      "ignore": ["src/styles/global.css"]
    },
    "packages/runtime": {
      "entry": ["scripts/generate-json-schema.ts"]
    },
    "apps/mesh": {
      "entry": [
        "src/cli.ts",
        "migrations/**/*.ts",
        "scripts/**/*.ts",
        // Dev-only module loaded via require() - needs explicit entry
        "src/api/routes/dev-only.ts"
      ],
      "ignore": [
        "src/api/index.ts",
        // Called from routes.ts in the next PR; unused here by design
        "src/monitoring/emit-llm-call.ts",
        "src/monitoring/record-llm-call-metrics.ts",
        // Wired into MeshContext in the next PR (context-factory.ts); unused here by design
        "src/storage/ai-provider-keys.ts",
        "src/storage/oauth-pkce-states.ts"
      ]
    },
    "packages/mesh-sdk": {
      "ignoreDependencies": ["sonner"]
    },
    "packages/typegen": {
      "ignore": ["src/*.test.ts"]
    }
  },
  "ignoreDependencies": ["@types/*"],
  // TODO(@camudo): Remove this config once I fix all unused type exports
  "ignoreIssues": {
    "**/*": ["types"],
    // MONITORING_LOG_TYPE_LLM_CALL and DECOPILOT_CONNECTION_ID are consumed by
    // emit-llm-call.ts / record-llm-call-metrics.ts, which are in the ignore
    // list until routes.ts wires them up in the next PR.
    "apps/mesh/src/monitoring/schema.ts": ["exports"]
  }
}
